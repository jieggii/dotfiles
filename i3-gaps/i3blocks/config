# i3blocks configuration file
#
# The i3blocks man page describes the usage of the binary,
# and its website describes the configuration:
#
#     https://vivien.github.io/i3blocks


# Global properties
separator=true
separator_block_width=20

#[public-ip]
#command=curl ipinfo.io/ip | awk '{print "IP: "$0}'
#interval=once


[weather]
full_text=Loading weather...
label=☁️ 
command=curl 'wttr.in/Kostomuksha?format=%t'
interval=3600
color=#A4C2F4


[date]
command=date '+%d.%m %H:%M'
interval=1
color=#f1ffc4

# AUR package: xkb-switch-git
[keymap]
label=⌨️ 
command=bash -c 'xkb-switch;xkb-switch -W' 
interval=persist
